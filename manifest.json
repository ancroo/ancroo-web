{
  "manifest_version": 3,
  "name": "Ancroo",
  "version": "0.0.0",
  "description": "AI Workflow Runner for your Browser",
  "permissions": [
    "activeTab",
    "sidePanel",
    "storage",
    "scripting",
    "clipboardRead",
    "clipboardWrite",
    "contextMenus",
    "identity",
    "downloads"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content/index.ts"]
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "Ancroo"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+Y"
      },
      "description": "Open Ancroo side panel"
    }
  },
  "icons": {
    "16": "public/icon-16.png",
    "48": "public/icon-48.png",
    "128": "public/icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "web_accessible_resources": [
    {
      "resources": ["request-mic.html", "request-mic.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
